    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "IN=$(cat); if printf '%s' \"$IN\" | grep -qiE '(>>?|[|;&][[:space:]]*tee[[:space:]])[^|;&]*(\\.devcontainer/|devcontainer\\.json|\\.husky/|\\.git/hooks/|\\.claude/settings)'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Blocked: shell write into a protected file (devcontainer config, git hooks, or claude settings). These files control host-side execution and must not be modified by the agent.\"}}'; exit 0; fi; if printf '%s' \"$IN\" | grep -qiE '\\.ssh/|\\.aws/|\\.gnupg/|id_rsa|id_ed25519|\\.netrc|\\.pgpass|master\\.key|\\.bundle/config|\\.gem/credentials|\\.pem([^A-Za-z0-9_]|$)|\\.p12([^A-Za-z0-9_]|$)|\\.pfx([^A-Za-z0-9_]|$)'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Blocked: command references a credential path (ssh/aws/gnupg keys, netrc, pgpass, certificates).\"}}'; exit 0; fi; if printf '%s' \"$IN\" | grep -qiE '\\.env([^A-Za-z0-9_]|$)|\\.envrc' && ! printf '%s' \"$IN\" | grep -qiE '\\.env[._-]?(example|sample|template|dist)'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Blocked: command references a .env file. Only .env.example/.env.sample style files may be touched.\"}}'; exit 0; fi",
            "statusMessage": "Checking command against protected paths"
          },
          {
            "type": "prompt",
            "if": "Bash(git push:*)",
            "prompt": "Review this git push command. DENY if it force-pushes in any form (-f, --force, --force-with-lease, --force-if-includes), deletes a remote branch (--delete or a :branch refspec), or pushes directly to main, master, develop, or a release/* branch. ALLOW a normal push to a feature/ticket branch. $ARGUMENTS"
          },
          {
            "type": "prompt",
            "if": "Bash(gh api:*)",
            "prompt": "Review this gh api command. ALLOW read-only requests (GET, no --method/-X mutation) and creating or replying to pull request comments and review comments. DENY merging pull requests, deleting any resource, or changing repository/organization settings, branch protection, workflows, webhooks, deploy keys, or secrets. $ARGUMENTS"
          }
        ]
      }
    ]
  },
  "skillListingBudgetFraction": 0.02,
  "enableArtifact": false,
  "enableWorkflows": false,
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": false,
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "stable",
  "theme": "auto",
  "preferredNotifChannel": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false
}
